# Postgres
POSTGRES_USER=youai
POSTGRES_PASSWORD=changeme
POSTGRES_DB=youai
DATABASE_URL=postgresql://youai:changeme@postgres:5432/youai

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_ENCRYPTION_KEY=changeme-generate-random
N8N_HOST=localhost
N8N_PORT=5678

# Telegram (optional — only needed if you activate Telegram workflows in n8n)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=changeme

# API Service
API_PORT=3000
API_HOST=0.0.0.0

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# OpenAI (optional — enables semantic/embedding-based contact search)
# OPENAI_API_KEY=sk-xxx

# Briefing
BRIEFING_HISTORY_COUNT=5
BRIEFING_CRON=0 7 * * *
ALERT_CRON=*/15 * * * *
