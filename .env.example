# Postgres
POSTGRES_USER=youai
POSTGRES_PASSWORD=changeme
POSTGRES_DB=youai
DATABASE_URL=postgresql://youai:changeme@postgres:5432/youai

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# Messaging (default: telegram)
MESSAGING_PROVIDER=telegram

# Telegram (only needed if MESSAGING_PROVIDER=telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# WhatsApp (only needed if MESSAGING_PROVIDER=whatsapp)
# Start with: docker compose --profile whatsapp up
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=changeme
EVOLUTION_INSTANCE=youai
WHATSAPP_OWNER_JID=

# Owner email (used to filter yourself out of contact imports)
OWNER_EMAIL=

# API Service
API_PORT=3000
API_HOST=0.0.0.0

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# OpenAI (optional — enables semantic/embedding-based contact search)
# OPENAI_API_KEY=sk-xxx

# Tavily Search API (optional — enables web search in briefings and chat)
# TAVILY_API_KEY=tvly-xxx

# GitHub (optional — enables github_activity briefing topic, higher rate limits)
# GITHUB_TOKEN=ghp_xxx

# Alpha Vantage (optional — alternative financial data provider for commodities/forex)
# ALPHA_VANTAGE_API_KEY=

# Briefing
BRIEFING_HISTORY_COUNT=5
BRIEFING_CRON=0 7 * * *
ALERT_CRON=*/15 * * * *
